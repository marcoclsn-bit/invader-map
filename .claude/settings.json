{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "git push 2>&1 || true",
            "if": "Bash(git commit*)",
            "statusMessage": "Push vers GitHub..."
          }
        ]
      }
    ]
  }
}
