{
  "expo": {
    "name": "InvaderQuest",
    "slug": "invaderquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Logo_White.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F0E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marco.invaderquest",
      "buildNumber": "1",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "comgooglemaps"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.marco.invaderquest",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0F0E"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "InvaderQuest utilise votre position pour vous situer sur la carte et vous aider à trouver les Invaders proches.",
          "locationAlwaysAndWhenInUsePermission": "InvaderQuest peut vous alerter quand vous passez près d'un Invader non flashé, même app fermée (Mode balade).",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#3DF96B"
        }
      ],
      "expo-localization",
      "expo-mail-composer"
    ],
    "extra": {
      "eas": {
        "projectId": "60322774-f3cf-427f-b11f-6b17da413e41"
      }
    }
  }
}
