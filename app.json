{
  "expo": {
    "name": "InvaderQuest",
    "slug": "invaderquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Logo_White.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F0E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marco.invaderquest",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "comgooglemaps"
        ]
      }
    },
    "android": {
      "package": "com.marco.invaderquest",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0F0E"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "InvaderQuest utilise votre position pour vous situer sur la carte et vous aider à trouver les Invaders proches."
        }
      ],
      "expo-localization",
      "expo-mail-composer"
    ]
  }
}
